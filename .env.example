# 应用基础
APP_NAME=geetar-agent
APP_ENV=dev
APP_VERSION=0.1.0

# 服务器
HOST=0.0.0.0
PORT=8000

# ─── LLM 网关（火山方舟编程套餐） ──────────────────────
LLM_API_KEY=
LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3
LLM_MODEL=glm-5.2
LLM_FAST_MODEL=glm-5-flash

# ─── LangSmith ─────────────────────────────────────────
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=geetar-agent-dev
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
